# target.env — per-app config for this ZAP DAST tool (localStorage-Bearer auth only).
# Fill these in for your app, then run `./run-docker.sh` (it sources this file).
#
# HOW TO FIND EACH VALUE — all via browser DevTools (F12), one-time, ~10 min:

# --- URLs -------------------------------------------------------------------
# APP_URL   : your app's base origin (from the address bar)
# API_URL   : DevTools > Network > click any XHR/fetch call > its host
# LOGIN_URL : the page that has the "Log In" button (usually the landing/home page)
# START_URL : an authenticated page to start crawling from (e.g. the dashboard)
APP_URL="https://app.example.com"
API_URL="https://api.example.com"
LOGIN_URL="${APP_URL}/landing"
START_URL="${APP_URL}/dashboard"

# --- Login form -------------------------------------------------------------
# DevTools > Elements > right-click the element > Copy > Copy selector / Copy XPath
# BTN_XPATH : the "Log In" button on LOGIN_URL
# USER_SEL  : the email/username input (CSS selector)
# PASS_SEL  : the password input (CSS selector)
BTN_XPATH="//button[normalize-space()='Log In']"
USER_SEL="#username"
PASS_SEL="#password"

# --- Token ------------------------------------------------------------------
# DevTools > Application > Local Storage > your domain > the key whose value starts "eyJ"
TOKEN_KEY="id_token"

# --- How the token is sent to the API ---------------------------------------
# DevTools > Network > an API request > Request Headers > the auth header
# AUTH_HEADER : the header name (usually Authorization)
# AUTH_PREFIX : text before the token, INCLUDING the trailing space (usually "Bearer ")
AUTH_HEADER="Authorization"
AUTH_PREFIX="Bearer "

# --- Logged-in check --------------------------------------------------------
# Pick a small authenticated API endpoint that is 200 with the token, 403/401 without.
# VERIFY_URL     : that endpoint
# LOGGEDIN_REGEX : a stable string in its 200 body that is NOT in the 403 (e.g. a field name)
VERIFY_URL="${API_URL}/v1/users/profile"
LOGGEDIN_REGEX="userId"

# --- Naming -----------------------------------------------------------------
# CONTEXT_NAME names the ZAP context and seeds the report filenames
# (e.g. "MyApp" -> myapp-zap-report-<ts>.html). No spaces preferred.
CONTEXT_NAME="MyApp"
